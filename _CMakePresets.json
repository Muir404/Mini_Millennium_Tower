{
  "version": 7,
  "configurePresets": [
    {
      "name": "TDPreset",
      "displayName": "Clang + Ninja (C++20)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-clang-ninja",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_CXX_STANDARD": "20",
        "CMAKE_CXX_STANDARD_REQUIRED": "ON",
        "CMAKE_CXX_EXTENSIONS": "OFF",
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_SHARED_LIBS": "OFF",
        "ENABLE_ASAN": "OFF" 
      }
    },
    {
      "name": "TDPreset-asan",
      "displayName": "Clang + Ninja (ASan Memory Check)",
      "description": "启用 AddressSanitizer 进行内存泄漏和越界检查",
      "inherits": "TDPreset",
      "cacheVariables": {
        "ENABLE_ASAN": "ON"
      }
    },
    {
      "name": "TDPreset-release",
      "displayName": "Clang + Ninja (C++20 Release)",
      "inherits": "TDPreset",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "ENABLE_ASAN": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "build-TDPreset",
      "configurePreset": "TDPreset",
      "jobs": 12
    },
    {
      "name": "build-asan",
      "configurePreset": "TDPreset-asan",
      "jobs": 12
    }
  ]
}